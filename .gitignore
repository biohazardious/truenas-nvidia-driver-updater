# Build artifacts
output/
*.raw

# User configuration (generated by configure.sh)
.env

# Backups (created by deploy-nvidia.sh)
backups/

# TrueNAS update files (large, ~1.8 GB)
*.update
truenas.update

# Persistent download cache (created by the docker-compose ./cache mount)
cache/

# User-supplied driver source patches (manual patch mode)
patches/

# Downloaded predefined patch files (the PATCHES.list manifests stay tracked)
predefined-patches/**/*.patch
predefined-patches/**/*.diff

# Docker build cache
.docker/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.code-workspace

# Logs
*.log

# Claude
CLAUDE.md
.claude/
.wolf/